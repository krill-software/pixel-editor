{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixel Editor",
  "version": "0.1.0",
  "identifier": "software.krill.pixel-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pixel Editor",
        "width": 1296,
        "height": 800,
        "minWidth": 720,
        "minHeight": 445,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A pixel-art editor for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to a PNG file to open"
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3Nzg5QTc4MEExOTM4MjIKUldRaU9Ca0tlSnA0aDQzcXJLRWtKWTI0K0lDM3IwTW4wcGUzdFZ5RE01ckYraU5nL1FRZWRXRmgK",
      "endpoints": [
        "https://github.com/krill-software/pixel-editor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Pixel-art editor",
    "longDescription": "A small pixel-art editor for Linux. Set a grid size, pick a color, place pixels, and save as a PNG where one cell is one image pixel.",
    "fileAssociations": [
      {
        "ext": [
          "png"
        ],
        "name": "PNG image",
        "description": "PNG image",
        "mimeType": "image/png",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "section": "graphics",
        "priority": "optional",
        "desktopTemplate": "main.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
